=> org.eclipse.ui.views.WorkbenchViewerSetup.setupViewer($viewer);
   $viewer.setInput($viewer)
;;

org.eclipse.core.runtime.Platform.OS_MACOSX.equals(org.eclipse.core.runtime.Platform.getOS())
=> org.eclipse.core.runtime.Platform.OS.isMac()
;;

org.eclipse.core.runtime.Platform.OS_WIN32.equals(org.eclipse.core.runtime.Platform.getOS())
