@id: jdt.internal.formatter.versioner.currentversion.update.to.20
@severity: info
"Updates the internal formatter profile version from VERSION_19 to VERSION_20.":
org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.CURRENT_VERSION = org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.VERSION_19
=> org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.CURRENT_VERSION = org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.VERSION_20
;;

@id: jdt.internal.formatter.versioner.currentversion.update.to.21
@severity: info
"Updates the internal formatter profile version from VERSION_20 to VERSION_21.":
org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.CURRENT_VERSION = org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.VERSION_20
=> org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.CURRENT_VERSION = org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.VERSION_21
;;

org.eclipse.jdt.internal.ui.preferences.formatter.FormatterModifyDialog.$builder.pref(org.eclipse.jdt.internal.ui.preferences.formatter.FormatterMessages.FormatterModifyDialog_lineWrap_pref_implements_clause, org.eclipse.jdt.core.formatter.DefaultCodeFormatterConstants.FORMATTER_ALIGNMENT_FOR_SUPERINTERFACES_IN_TYPE_DECLARATION) :: sourceVersionGE(15)
=> org.eclipse.jdt.internal.ui.preferences.formatter.FormatterModifyDialog.$builder.pref(org.eclipse.jdt.internal.ui.preferences.formatter.FormatterMessages.FormatterModifyDialog_lineWrap_pref_implements_clause, org.eclipse.jdt.core.formatter.DefaultCodeFormatterConstants.FORMATTER_ALIGNMENT_FOR_SUPERINTERFACES_IN_TYPE_DECLARATION).pref(org.eclipse.jdt.internal.ui.preferences.formatter.FormatterMessages.FormatterModifyDialog_lineWrap_pref_permits_clause, org.eclipse.jdt.core.formatter.DefaultCodeFormatterConstants.FORMATTER_ALIGNMENT_FOR_PERMITTED_TYPES_IN_TYPE_DECLARATION)
;;