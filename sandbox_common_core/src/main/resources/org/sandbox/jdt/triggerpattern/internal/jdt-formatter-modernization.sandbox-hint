@id: jdt.internal.formatter.versioner.currentversion.update
@severity: info
"Updates the internal formatter profile version from VERSION_18 to VERSION_19.":
org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.CURRENT_VERSION = org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.VERSION_18
=> org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.CURRENT_VERSION = org.eclipse.jdt.internal.ui.preferences.formatter.ProfileVersioner.VERSION_19
;;

@id: jdt.internal.formatter.record.indentation.type-to-record
@severity: info
"Maps old formatter indentation settings for types to new settings for record declarations.":
org.eclipse.jdt.core.formatter.DefaultCodeFormatterConstants.FORMATTER_INDENT_BODY_DECLARATIONS_COMPARE_TO_TYPE_HEADER :: sourceVersionGE(14)
=> org.eclipse.jdt.core.formatter.DefaultCodeFormatterConstants.FORMATTER_INDENT_BODY_DECLARATIONS_COMPARE_TO_RECORD_HEADER
;;

