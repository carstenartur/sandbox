<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension-point id="org.sandbox.jdt.triggerpattern.hints" name="Trigger Pattern Hints" schema="schema/org.sandbox.jdt.triggerpattern.hints.exsd"/>
   <extension-point id="org.sandbox.jdt.triggerpattern.guards" name="Trigger Pattern Guards" schema="schema/org.sandbox.jdt.triggerpattern.guards.exsd"/>
   
   <extension
         point="org.eclipse.jdt.ui.quickAssistProcessors">
      <quickAssistProcessor
            class="org.sandbox.jdt.triggerpattern.ui.TriggerPatternQuickAssistProcessor"
            id="org.sandbox.jdt.triggerpattern.quickAssist"
            name="Trigger Pattern Quick Assist">
      </quickAssistProcessor>
      <quickAssistProcessor
            class="org.sandbox.jdt.triggerpattern.ui.HintFileQuickAssistProcessor"
            id="org.sandbox.jdt.triggerpattern.hintFileQuickAssist"
            name="Hint File Quick Assist">
      </quickAssistProcessor>
   </extension>
   
   <extension
         point="org.sandbox.jdt.triggerpattern.hints">
      <hintProvider
            class="org.sandbox.jdt.triggerpattern.examples.ExampleHintProvider">
      </hintProvider>
   </extension>
   
   <extension
         id="org.sandbox.jdt.triggerpattern.hint"
         point="org.eclipse.core.resources.markers">
      <super type="org.eclipse.core.resources.problemmarker"/>
      <super type="org.eclipse.core.resources.textmarker"/>
      <persistent value="false"/>
   </extension>
   
   <extension
         id="org.sandbox.jdt.triggerpattern.embeddedJavaProblem"
         point="org.eclipse.core.resources.markers">
      <super type="org.eclipse.core.resources.problemmarker"/>
      <super type="org.eclipse.core.resources.textmarker"/>
      <persistent value="false"/>
   </extension>
   
   <extension
         id="org.sandbox.jdt.triggerpattern.executionTrace"
         point="org.eclipse.core.resources.markers">
      <super type="org.eclipse.core.resources.textmarker"/>
      <persistent value="false"/>
      <attribute name="ruleId"/>
      <attribute name="hintFile"/>
      <attribute name="replacement"/>
      <attribute name="timestamp"/>
   </extension>
   
   <extension
         point="org.eclipse.core.contenttype.contentTypes">
      <content-type
            id="org.sandbox.jdt.triggerpattern.sandboxHintContentType"
            name="Sandbox Hint File"
            file-extensions="sandbox-hint"
            base-type="org.eclipse.core.runtime.text"
            priority="normal">
      </content-type>
   </extension>
   
   <extension
         point="org.eclipse.ui.editors">
      <editor
            id="org.sandbox.jdt.triggerpattern.editor.sandboxHint"
            name="Sandbox Hint Editor"
            class="org.sandbox.jdt.triggerpattern.editor.SandboxHintEditor"
            extensions="sandbox-hint"
            default="true"
            contributorClass="org.eclipse.ui.texteditor.BasicTextEditorActionContributor">
      </editor>
   </extension>
   
   <extension
         point="org.eclipse.ui.console.consoleFactories">
      <consoleFactory
            class="org.sandbox.jdt.triggerpattern.ui.SandboxHintConsoleFactory"
            label="Sandbox Hint Execution">
      </consoleFactory>
   </extension>
   
   <extension
         point="org.eclipse.debug.core.launchConfigurationTypes">
      <launchConfigurationType
            id="org.sandbox.jdt.triggerpattern.debug.sandboxHintLaunch"
            name="Sandbox Hint Debug"
            delegate="org.sandbox.jdt.triggerpattern.debug.SandboxHintLaunchConfigurationType"
            modes="debug">
      </launchConfigurationType>
   </extension>
   
   <extension
         point="org.eclipse.debug.core.sourceLocators">
      <sourceLocator
            id="org.sandbox.jdt.triggerpattern.debug.sourceLocator"
            name="Sandbox Hint Source Locator"
            class="org.sandbox.jdt.triggerpattern.debug.SandboxHintSourceLocator">
      </sourceLocator>
   </extension>
   
   <extension
         point="org.eclipse.debug.core.sourcePathComputers">
      <sourcePathComputer
            id="org.sandbox.jdt.triggerpattern.debug.sourcePathComputer"
            class="org.sandbox.jdt.triggerpattern.debug.SandboxHintSourcePathComputer">
      </sourcePathComputer>
   </extension>
</plugin>
